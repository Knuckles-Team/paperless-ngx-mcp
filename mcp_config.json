{
  "mcpServers": {
    "paperless-ngx-mcp": {
      "command": "uv",
      "args": [
        "run",
        "paperless-ngx-mcp"
      ],
      "env": {
        "PAPERLESS_URL": "<YOUR_PAPERLESS_URL>",
        "PAPERLESS_TOKEN": "<YOUR_PAPERLESS_TOKEN>",
        "PAPERLESS_SSL_VERIFY": "<YOUR_PAPERLESS_SSL_VERIFY>",
        "DOCUMENTSTOOL": "True",
        "SYSTEMTOOL": "True"
      }
    }
  }
}
