{
  "mcpServers": {
    "paperless-ngx-mcp": {
      "command": "uv",
      "args": [
        "run",
        "paperless-ngx-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "DOCUMENTSTOOL": "True",
        "PAPERLESS_TOKEN": "your_token_here",
        "PAPERLESS_URL": "http://localhost:8000",
        "SYSTEMTOOL": "True"
      }
    }
  }
}
